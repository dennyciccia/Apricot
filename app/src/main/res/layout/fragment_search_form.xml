<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.fragments.SearchFormFragment">

    <TextView
        android:id="@+id/textViewInsertDishInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/insert_dish_info"
        android:textStyle="bold"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/textViewInsertDishInfo">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewInsertIngredients"
                android:text="@string/ingredients"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/editTextIngredients"
                android:hint="@string/hint_edit_text_ingredients"
                android:maxWidth="200dp"
                android:ellipsize="end" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewQuery"
                android:text="@string/query"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/editTextQuery"
                android:hint="@string/hintEditTextQuery"
                android:maxWidth="200dp"
                android:ellipsize="end" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewType"
                android:text="@string/type"
                android:layout_weight="1" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/selectDishTypeLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="@string/type">
                <AutoCompleteTextView
                    android:id="@+id/selectDishType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="200dp"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewGlutenFree"
                android:text="@string/gluten_free_only"
                android:layout_weight="1" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchGlutenFree"
                android:layout_width="wrap_content"/>

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewOnlyVegetarian"
                android:text="@string/vegetarian_only"
                android:layout_weight="1" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchVegetarian"
                android:layout_width="wrap_content"/>

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewOnlyVegan"
                android:text="@string/vegan_only"
                android:layout_weight="1" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchVegan"
                android:layout_width="wrap_content"/>

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewCuisines"
                android:text="@string/cuisines"
                android:layout_weight="1" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/selectCuisineLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="@string/cuisines">
                <AutoCompleteTextView
                    android:id="@+id/selectCuisines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="200dp"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewIntolerances"
                android:text="@string/intolerances"
                android:layout_weight="1" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/selectIntolerancesLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="@string/intolerances">
                <AutoCompleteTextView
                    android:id="@+id/selectIntolerances"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="200dp"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewMaxReadyTime"
                android:text="@string/max_ready_time"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/editTextMaxReadyTime"
                android:hint="@string/hint_edit_text_max_ready_time"
                android:maxWidth="200dp"
                android:ellipsize="end"
                android:inputType="number" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textViewResultsLimit"
                android:text="@string/results_limit"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/editTextResultsLimit"
                android:hint="@string/hint_edit_text_results_limit"
                android:maxWidth="200dp"
                android:ellipsize="end"
                android:inputType="number" />

        </TableRow>

    </TableLayout>

    <Button
        android:id="@+id/buttonSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/search"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>